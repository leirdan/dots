" {{{ GLOBAL
set relativenumber
set nowrap
set encoding=utf-8
syntax enable
filetype plugin indent on
set foldenable
set foldmethod=indent
set foldlevelstart=99
" }}}

" {{{ IDENTATION 
set autoindent
set cindent
set shiftwidth=2
set expandtab
set smarttab
set softtabstop=2
set tabstop=2
" }}}

" {{{ SEARCH
set hlsearch
set ignorecase 
" }}}

" {{{ KEYBINDS  
map <space> /
" }}}

" {{{ SCRIPTS 
" Fold method
augroup vim_config
  autocmd!
  autocmd BufRead,BufNewFile vimcfg,hyprland.conf,hyprlock.conf setfiletype cfg 
  autocmd FileType cfg setlocal foldmethod=marker
augroup END
" Init templates 
autocmd BufNewFile *.tex 0r ~/dots/vim/templates/skeleton.tex
" }}}

" {{{ PLUGINS 
call plug#begin("~/.vim/plugged")
Plug 'rust-lang/rust.vim'
Plug 'dense-analysis/ale'
Plug 'vim-airline/vim-airline'
Plug 'vim-airline/vim-airline-themes'
Plug 'scrooloose/nerdtree'
Plug 'ryanoasis/vim-devicons'
call plug#end()

" rust.vim options
"let g:rustfmt_autosave=1

" ale options
let g:ale_fix_on_save=1
let g:ale_linters={
\		'rust': ['analyzer', 'cargo'],
\		'latex': ['textlint'],
\}

let g:ale_fixers={
\		'rust': ['rustfmt'],
\}
let g:ale_rust_rustfmt_use_cargo=1
let g:ale_rust_rustfmt_options='--edition 2024'
let g:ale_completion_enabled=1
let g:ale_completion_autoimport=1
let g:ale_sign_error = '>>'
let g:ale_sign_warning = '--'
let g:ale_echo_msg_error_str = 'ERR'
let g:ale_echo_msg_warning_str = 'W'
let g:ale_echo_msg_format = '[%linter%] %s [%severity%]'

" vim-airline options
let g:airline#extensions#ale#enabled = 1
let g:airline_theme='deus'

" nerdtree options
let g:NERDTreeFileLines = 1
let g:NERDTreeShowHidden=1
let g:NERDTreeWinPos = "right"
nnoremap <C-b> :NERDTreeToggle<CR>
" Start NERDTree while opening Vim and put cursor on file
autocmd VimEnter * NERDTree | wincmd p 
" Close NERDTree automatically if it's the last thing on screen
autocmd bufenter * if (winnr("$") == 1 && exists("b:NERDTree") && b:NERDTree.isTabTree()) | q | endif 

" }}}
